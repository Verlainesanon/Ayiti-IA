# Variables d'environnement Ayiti-AI
# Copier ce fichier en .env et remplir les valeurs

# ── HuggingFace ──────────────────────────────────────────────────────────────
HF_TOKEN=hf_...
HUGGINGFACE_HUB_CACHE=./cache/hub

# ── Weights & Biases ─────────────────────────────────────────────────────────
WANDB_API_KEY=...
WANDB_PROJECT=ayiti-ai
WANDB_ENTITY=your-username

# ── Argilla (qualité des données) ────────────────────────────────────────────
ARGILLA_API_KEY=...
ARGILLA_API_URL=http://localhost:6900

# ── OpenAI (LLM-as-judge, optionnel) ────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── AWS S3 (stockage DVC, optionnel) ─────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
DVC_REMOTE_URL=s3://ayiti-ai-data/dvc-store
